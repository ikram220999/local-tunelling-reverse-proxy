server {
    listen 80;
    listen [::]:80;

    server_name *.uplinkr.xyz;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;

    server_name ~^(?<tunnel_id>[^.]+)\.uplinkr\.xyz$;

    ssl_certificate /etc/letsencrypt/live/uplinkr.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/uplinkr.xyz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    error_page 500 502 504 =200 /error.html;
    error_page 503 =200 /503.html;
    error_page 404 =200 /404.html;

    location / {
        limit_req zone=uplinkrLimit burst=20 nodelay;

        proxy_pass http://localhost:4001;
        proxy_set_header Accept-Encoding "";
        proxy_set_header X-Tunnel-Id $tunnel_id;

        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_intercept_errors on;

        proxy_connect_timeout 5s;
        proxy_read_timeout 15s;
        proxy_send_timeout 15s;
    }

    location = /error.html {
        internal;
        root /var/www/html/uplinkr-fallback;
    }

    location = /503.html {
        internal;
        root /var/www/html/uplinkr-fallback;
    }

    location = /404.html {
        internal;
        root /var/www/html/uplinkr-fallback;
    }
}